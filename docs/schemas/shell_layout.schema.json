{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://draftsman.local/shell_layout.schema.json",
  "title": "Draftsman Shell Layout",
  "type": "object",
  "required": ["app_title", "left_rail", "tabs", "panels", "inspector"],
  "additionalProperties": true,
  "properties": {
    "app_title": { "type": "string" },
    "left_rail": {
      "type": "object",
      "required": ["sections"],
      "properties": {
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/rail_section" }
        }
      }
    },
    "tabs": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" }
    },
    "panels": {
      "type": "array",
      "items": { "$ref": "#/$defs/panel" }
    },
    "inspector": {
      "type": "object",
      "required": ["panels"],
      "properties": {
        "panels": {
          "type": "array",
          "items": { "$ref": "#/$defs/panel" }
        }
      }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" }
      }
    },
    "rail_section": {
      "type": "object",
      "required": ["id", "title", "items"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/item" }
        }
      }
    },
    "panel": {
      "type": "object",
      "required": ["id", "label", "tab"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "tab": { "type": "string", "minLength": 1 },
        "lines": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "text": { "type": "string" },
        "min_height": { "type": "integer", "minimum": 32 },
        "subtle": { "type": "boolean" },
        "enabled": { "type": "boolean" }
      }
    }
  }
}
