{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Draftsman Feature Registry",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "features"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "feature_id",
          "label",
          "status",
          "renderer_type",
          "enabled"
        ],
        "properties": {
          "feature_id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "renderer_type": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "target_surfaces": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "settings": {
            "type": "object"
          }
        }
      }
    }
  }
}
