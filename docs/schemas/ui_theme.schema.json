{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://draftsman.local/ui_theme.schema.json",
  "title": "Draftsman UI Theme",
  "type": "object",
  "required": ["base", "surface", "accent"],
  "additionalProperties": false,
  "properties": {
    "base": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "surface": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "accent": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    }
  }
}
