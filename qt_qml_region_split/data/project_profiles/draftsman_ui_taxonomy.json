{
  "schema_version": 1,
  "profile": {
    "profile_id": "draftsman_ui_taxonomy",
    "label": "Draftsman",
    "type": "meta_review",
    "root_path": "",
    "summary": "Meta review workspace for the Draftsman shell UI taxonomy.",
    "default_activity": "review"
  },
  "activity_modes": [
    {
      "id": "blank",
      "label": "Blank",
      "icon": "B",
      "tooltip": "Blank workspace",
      "enabled": true
    },
    {
      "id": "review",
      "label": "Review",
      "icon": "R",
      "tooltip": "Review gate workspace",
      "enabled": true
    },
    {
      "id": "settings",
      "label": "Settings",
      "icon": "S",
      "tooltip": "Settings surface",
      "enabled": true
    },
    {
      "id": "proof",
      "label": "Proof",
      "icon": "P",
      "tooltip": "Proof and receipts",
      "enabled": true
    }
  ],
  "left_panel": {
    "project_rows": [
      {
        "label": "Project slot",
        "meta": "meta"
      },
      {
        "label": "Scratch",
        "meta": "workflow"
      },
      {
        "label": "Final",
        "meta": "workflow"
      }
    ],
    "settings_label": "Theme and layout"
  },
  "main_workspace": {
    "feature": "ui_taxonomy_review"
  },
  "right_inspector": {
    "source": "selected_route",
    "sections": {
      "facts": true,
      "selection": true,
      "code_refs": true,
      "notes": true,
      "receipts": true,
      "actions": true
    }
  },
  "bottom_panel": {
    "tabs": [
      "Output",
      "Proof",
      "Receipts",
      "Log"
    ]
  },
  "data_sources": {
    "review_subject": "data/review_subjects/draftsman_ui_taxonomy.json",
    "review_notes": "data/review_notes/draftsman_ui_taxonomy_notes.json"
  },
  "write_policy": {
    "writes_enabled": false,
    "note_storage": "memory"
  }
}
